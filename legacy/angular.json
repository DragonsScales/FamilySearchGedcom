{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "familysearch-extension-app": {
      "projectType": "application",
      "root": "extension-app",
      "sourceRoot": "extension-app/src",
      "prefix": "fsg",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": {
              "base": "extension/familysearch-collector/app",
              "browser": ""
            },
            "index": "extension-app/src/index.html",
            "browser": "extension-app/src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "extension-app/tsconfig.app.json",
            "baseHref": "./",
            "inlineStyleLanguage": "css",
            "assets": [],
            "styles": ["extension-app/src/styles.css"],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [],
              "outputHashing": "none",
              "optimization": {
                "scripts": true,
                "styles": {
                  "minify": true,
                  "inlineCritical": false
                },
                "fonts": false
              },
              "sourceMap": false,
              "namedChunks": false
            },
            "development": {
              "outputHashing": "none",
              "optimization": false,
              "sourceMap": true,
              "namedChunks": true
            }
          },
          "defaultConfiguration": "production"
        }
      }
    }
  },
  "cli": {
    "analytics": "80e02fa3-7705-4390-882b-bde3b2a8912d"
  }
}
